# copy to .env and fill in your values

# github personal access token (needs repo scope)
GITHUB_TOKEN=ghp_your_token_here

# github webhook secret (set when creating the webhook)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# anthropic API key for Claude (review comment generation)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# set to 'production' to disable /docs
CODESENTRY_ENV=development
